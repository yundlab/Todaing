# PC 브라우저만 쓸 때 (웹은 기본 http://localhost:5176 — `vite.config.ts` server.port)
VITE_API_BASE_URL=http://localhost:8787
# 같은 Wi-Fi에서 휴대폰으로 접속할 때: PC의 사설 IP로 바꿔야 합니다. (localhost 쓰면 폰→폰 자신이라 연결 거절)
# 예: VITE_API_BASE_URL=http://192.168.0.12:8787
# + Google Cloud Console → 해당 웹 클라이언트 → 승인된 리디렉션 URI에
#   http://192.168.0.12:8787/auth/google 도 추가

# 버스 정류장 검색은 위 API(apps/api)의 /api/transit/tago 로 프록시됩니다.
# TAGO 키: apps/api/.env 의 TAGO_SERVICE_KEY
# 서울 시내버스 보완(ws.bus.go.kr): 같은 파일의 SEOUL_BUS_SERVICE_KEY(별도 발급)

# Google Identity Services (Web client ID)
# 예: 1234567890-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

