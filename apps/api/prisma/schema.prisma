generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expenses  Expense[]
  schedules ScheduleItem[]
}

model Expense {
  id         String   @id @default(cuid())
  occurredAt DateTime
  endAt      DateTime?
  amount     Int
  category   String
  merchant   String?
  /** 결제 건 제목(실지출). */
  subject    String?
  detail     String?
  memo       String?

  paymentType        PaymentType @default(CARD) // 카드/현금/계좌 등
  paymentOwner       String?
  paymentMethodLabel String?
  installment             Boolean @default(false)
  installmentMonths       Int?
  installmentNoInterest   Boolean @default(false)

  // 결제일(occurredAt)과 다른 "사용 예정/실제일". null이면 결제일과 동일.
  plannedAt               DateTime?
  plannedEndAt            DateTime?
  plannedMemo             String?
  /** 다른 날 사용 — 실제 이용 내용(제목과 별도). */
  plannedContent          String?
  plannedDetail           String?
  plannedCompanionsText   String?

  scope              ExpenseScope @default(PERSONAL)
  participants       Json?        // 공동 정산 멤버 목록 (예: ["나","친구1"])

  // 교통 입력용 (선택)
  transitFrom        String?
  transitTo          String?
  transitVia         String?
  transitLine        String?
  transitMode        String?
  transitBusNumber   String?
  transitSegments    Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([occurredAt])
  @@index([plannedAt])
  @@index([createdAt])
}

enum ExpenseScope {
  PERSONAL
  SHARED
}

model ScheduleItem {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime?
  title     String
  note      String?
  showOnCalendar Boolean @default(false)
  repeatYearly   Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startAt])
  @@index([endAt])
}

enum PaymentType {
  CARD
  CASH
  ACCOUNT
  ETC
}

