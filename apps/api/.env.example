PORT=8787
# 브라우저 주소창에 실제로 쓰는 웹 앱 URL과 같게 두세요. (구글 로그인 후 리다이렉트 폴백)
# Todaing 웹 기본 포트는 5176. Vite 포트를 바꾸면 여기도 동일 origin으로 맞출 것. (구글 리디렉션 URI는 쿼리 없이 `/auth/google`만 등록하는 것이 안전)
WEB_ORIGIN=http://localhost:5176
# 같은 Wi-Fi에서 휴대폰으로 테스트할 때는 PC IP로 맞춤:
# WEB_ORIGIN=http://192.168.0.12:5176

# Supabase Postgres 연결 문자열 (Project Settings → Database → Connection string)
# 예: postgresql://postgres:<PASSWORD>@db.<ref>.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# 세션 JWT(HMAC) 서명 — 프로덕션에서는 32자 이상 난수로 바꾸세요. 미설정 시 개발용 기본값이 쓰입니다.
AUTH_SESSION_SECRET=

# 국토교통부 TAGO 버스(도시코드·노선·경유정류장) — 공공데이터포털(data.go.kr) 일반 인증키
# 웹이 아니라 API 서버에서만 사용합니다. 비우면 앱에서 “버스 정류장 찾기”가 비활성됩니다.
# 프로덕션(Vercel 웹 등)에서도 이 키는 “API를 돌리는 호스트”에만 넣으면 됩니다. Vercel 정적 빌드에는 불필요합니다.
# Encoding 키(값에 %xx 가 포함되는 경우)를 그대로 붙이세요. 따옴표는 생략하는 것을 권장합니다.
TAGO_SERVICE_KEY=

# 서울 열린데이터광장(data.seoul.go.kr) 인증키 — 정류장 시트: `.../json/busRteInfo/시작/끝/` (실패 시 busRouteInfo 폴백)
# 서울 시내버스 노선·정류장의 1순위 소스(시트 페이징·검색 시 호출 여러 번 가능). 비우면 서울은 TAGO만 사용합니다.
SEOUL_OPEN_DATA_PLAZA_KEY=

# (선택) 공공데이터포털「서울특별시_노선정보조회」(ws.bus.go.kr) 일반 인증키 — `SEOUL_OPEN_DATA_PLAZA_KEY` 없이 이것만 있어도 서울 cityCode로 `/routes` 시 WS 우선 호출됨
# SEOUL_BUS_WS_SERVICE_KEY=
# WS가 응답 없이 멈추면(로컬망 등) 폴백까지 오래 걸리므로 기본 8초에 끊음. 필요 시 3000~20000
# SEOUL_WS_FETCH_TIMEOUT_MS=8000
# WS를 아예 쓰지 않으려면(열린데이터+TAGO만): SEOUL_WS_BUS_DISABLED=1
# 서울 노선만 WS 한 번으로 제한(폴백·전국 TAGO 스캔 없음) — 느림 원인 분리용: SEOUL_BUS_ROUTES_WS_ONLY=1
# 서울을 “열린데이터광장만”으로 강제(WS/TAGO/enrich 스킵) — 가장 빠르게 단순화: SEOUL_BUS_OPEN_DATA_ONLY=1
# 서울만 PLAZA 경량 + 지방·routes-broad 는 TAGO(전국 broad 유지): SEOUL_BUS_ROUTES_PLAZA_LIGHT=1

